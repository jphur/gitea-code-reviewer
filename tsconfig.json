{
    "compilerOptions": {
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "src",
        "resolveJsonModule": true,
        "allowJs": false,
        "declaration": true,
        "sourceMap": true,
        "incremental": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
