{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Node",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "outDir": "../dist",
        "rootDir": "./",
        "resolveJsonModule": true,
        "allowJs": false,
        "declaration": true,
        "sourceMap": true,
        "incremental": true
    },
    "include": ["./**/*.ts"],
    "exclude": ["../node_modules", "../dist"]
}
