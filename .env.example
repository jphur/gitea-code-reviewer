# Gitea configuration
GITEA_URL=http://your-gitea-server
GITEA_TOKEN=your_gitea_api_token
GITEA_WEBHOOK_SECRET=your_webhook_secret
# Git username that the bot listens for as reviewer (e.g. "AI")
BOT_NAME=AI

# Google Generative AI key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key

# HTTP server (optional defaults shown)
PORT=4000
ENDPOINT=0.0.0.0

# Review thresholds
REQUEST_CHANGES_THRESHOLD=8

# Network/timeouts
GITEA_TIMEOUT_MS=15000
AI_TIMEOUT_MS=60000
MAX_DIFF_CHARS=200000
REQUEST_RETRY_COUNT=2
REQUEST_RETRY_DELAY_MS=500
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
